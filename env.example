# Base de datos (requerido)
DATABASE_URL=postgresql://postgres:PASSWORD@host:5432/db
DATABASE_DIRECT_URL=postgresql://postgres:PASSWORD@host:5432/db

# Redis (requerido)
REDIS_URL=redis://default:PASSWORD@host:6379

# JWT (requerido)
# Genera con: node -e "require('crypto').randomBytes(64).toString('base64')"
JWT_SECRET=tu_jwt_secret_aqui

# Servidor
PORT=3001
WEB_ORIGIN=http://localhost:5173
NODE_ENV=development

# Campo Files API (opcional)
FILES_API_URL=https://campo-api-files-campo-saas.up.railway.app
FILES_API_KEY=tu_api_key