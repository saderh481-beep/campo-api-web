    "bcryptjs": "^2.4.3",
    "hono": "^4.12.11",
    "ioredis": "^5.10.1",
    "jose": "^5.10.0",
    "pdf-lib": "^1.17.1",
    "postgres": "^3.4.9",
    "undici": "^8.0.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/bun": "latest",
    "@types/node": "^25.5.2",
    "typescript": "^5.9.3"
  }
}
