{
  "name": "api-web",
  "version": "1.0.0",
  "private": true,
  "overrides": {
    "lodash": "^4.17.23"
  },
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "typecheck": "tsc --noEmit",
    "migrate": "bun run migrate.ts",
