# ── Base de datos ──────────────────────────────────────────────────────────────
# Local: usar DATABASE_PUBLIC_URL de Railway
# Producción (Railway): usar DATABASE_URL (red interna)
DATABASE_URL=postgresql://user:pass@host:5432/railway

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://default:pass@host:6379

# ── JWT ────────────────────────────────────────────────────────────────────────
# node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"
JWT_SECRET=reemplazar_con_64_bytes_base64

# ── Correo (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=noreply@tudominio.com

# ── Cloudflare R2 ──────────────────────────────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=campo-docs

# ── Archivado ──────────────────────────────────────────────────────────────────
# ⛔ Guardar en papel — nunca en servidor
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ARCHIVE_ENCRYPTION_KEY=reemplazar_con_32_bytes_hex

# ── Servidor ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
WEB_ORIGIN=http://localhost:5173
